# ─────────────────────────────────────────────────────────────────────────────
# .env.example — variáveis de TOOLING/CLI do Supabase (raiz do monorepo)
#
# Este arquivo é o nível de gerenciamento do backend (link, migrations, gen types).
# As chaves de RUNTIME dos apps ficam em cada app:
#   - apps/web/.env    → NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   - apps/mobile/.env → EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# Copie para `.env` (que já está no .gitignore) e preencha com os valores da sua
# CONTA PESSOAL do Supabase. NUNCA commite o `.env` — só este `.env.example`.
# ─────────────────────────────────────────────────────────────────────────────

# Personal Access Token da sua conta pessoal (Supabase → Account → Access Tokens).
# Tem PRIORIDADE sobre o login global do CLI: garante que todo comando neste
# projeto fale só com a sua conta, sem tocar em outras contas/connectors.
SUPABASE_ACCESS_TOKEN=

# Ref do projeto (o código no meio da URL: https://<REF>.supabase.co).
# Usado no `supabase link --project-ref $SUPABASE_PROJECT_REF`. Não é segredo.
SUPABASE_PROJECT_REF=

# anon / publishable key do projeto (Project Settings → API). Público por design.
SUPABASE_ANON_KEY=

# Senha do banco do projeto (definida na criação do projeto).
# Usada pelo `supabase link` / migrations de forma não-interativa.
SUPABASE_DB_PASSWORD=
